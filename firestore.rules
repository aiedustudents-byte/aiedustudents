rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Public content collections - allow read for all, write for authenticated users
    match /vibe_coding/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /news/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /projects/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /jobs/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /courses/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /lessons/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /prompt_engineering/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /simulator_tasks/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /ai_learning_tools/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /challenges/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /wellness_videos/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Domain Specific Prompt Engineering Guides
    match /prompt_engineering_guide_bcom/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /prompt_engineering_guide_bba/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /prompt_engineering_guide_civil/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // Art posts and related collections
    match /artPosts/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
      
      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow write: if isAuthenticated();
      }
    }
    
    // User-specific collections - users can only access their own data
    match /user_profiles/{userId} {
      allow read: if true; // Allow read for all (needed for admin views)
      allow write: if isAuthenticated();
    }
    
    match /user_progress/{progressId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    match /user_mood_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    match /user_mood_journals/{journalId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    // User points - allow read for all, write for authenticated
    match /userPoints/{userId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // Challenge submissions
    match /challengeSubmissions/{submissionId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // Test collection (for debugging)
    match /test/{document=**} {
      allow read, write: if isAuthenticated();
    }
    
    // Default rule - deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

